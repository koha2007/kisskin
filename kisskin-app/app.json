{
  "expo": {
    "name": "kissinskin",
    "slug": "kisskin-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.kissinskin.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "net.kissinskin.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES", "READ_EXTERNAL_STORAGE", "POST_NOTIFICATIONS"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "사진을 선택하려면 갤러리 접근 권한이 필요합니다.",
          "cameraPermission": "사진을 촬영하려면 카메라 권한이 필요합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#eb4763"
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "생성한 메이크업 이미지를 갤러리에 저장하려면 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "owner": "kissinskin",
    "extra": {
      "eas": {
        "projectId": "dbe9cc76-db58-41e5-8aaf-0532309e1198"
      }
    }
  }
}
