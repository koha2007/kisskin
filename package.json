{
  "name": "myapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vike prerender && cp dist/client/index.html dist/client/404.html && node -e \"const f='dist/client/_routes.json';const r=JSON.parse(require('fs').readFileSync(f));if(!r.include.includes('/result/*'))r.include.push('/result/*');require('fs').writeFileSync(f,JSON.stringify(r,null,2))\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vike": "^0.4.256",
    "vike-react": "^0.6.21"
  },
